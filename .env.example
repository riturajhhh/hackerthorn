# GenAI (OpenAI-compatible API key)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Slack incoming webhook (optional)
SLACK_WEBHOOK=

# Email alerts (optional; Gmail: use an App Password)
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_FROM=
EMAIL_TO=
EMAIL_USERNAME=
EMAIL_PASSWORD=

# Optional automation tuning
# AUTOMATION_REASSIGN_PROB_MIN=0.55
# AUTOMATION_ESCALATE_L1_PROB=0.72
# AUTOMATION_ESCALATE_L2_PROB=0.88
# EMPLOYEE_LOAD_CAP=10

# Pipeline speed (optional)
# SKIP_GENAI=1
# SKIP_SLACK=1
# SKIP_EMAIL=1   (skip SMTP digest)
# MAX_GENAI_ROWS=40
